# Zero Arena SDK — environment template.
# Copy to `.env` and fill in. Used by the `zeroarena` CLI and the example flows.

# Galileo testnet defaults — override only if 0G publishes new endpoints.
ZA_RPC=https://evmrpc-testnet.0g.ai
ZA_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# Your testnet wallet (must have Galileo gas — faucet at https://faucet.0g.ai).
PRIVATE_KEY=0x

# Deployed contract addresses — copy from contracts/deployments/galileo-testnet.json
# after running `forge script script/DeployAll.s.sol:DeployAll`.
ZA_ADDR_CERT=0x
ZA_ADDR_INFT=0x
ZA_ADDR_ORACLE=0x

# Required only for `transferAgent`. v0.1 oracle is a trusted-signer stub.
ORACLE_PRIVATE_KEY=0x

# Where AES keys are persisted after certify / mint. Defaults to ~/.zeroarena/keys.
# ZA_KEYS_DIR=
