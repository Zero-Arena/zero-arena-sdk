# Zero Arena SDK — environment template.
# Copy to `.env` and fill in. Used by the `zeroarena` CLI and the example flows.

# Galileo testnet defaults — override only if 0G publishes new endpoints.
ZA_RPC=https://evmrpc-testnet.0g.ai
ZA_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# YOUR wallet's private key. Pays gas for uploadDataset, certify, mintAgent.
# Must hold Galileo OG — faucet at https://faucet.0g.ai. This is NEVER anyone
# else's key. The SDK does not, and will never, ask you for a deployer or
# oracle private key.
PRIVATE_KEY=0x

# Deployed contract addresses. For Galileo testnet these are pinned in
# @zero-arena/contracts; override here only if you redeploy.
ZA_ADDR_CERT=0x21a5DEA59cfA07B261d389A9554477e137805c2f
ZA_ADDR_INFT=0x4Bd4d45f206861aa7cD4421785a316A1dD06036f
ZA_ADDR_ORACLE=0x63909dA30b0d65ad72b32b3C8C82515f7BFA6Fd6

# Where AES keys are persisted after certify / mint. Defaults to ~/.zeroarena/keys.
# ZA_KEYS_DIR=

# NOTE: There is NO oracle private key here. iNFT transfers (`transferAgent`)
# require constructing an `HttpOracleClient` at the call site, pointing at a
# running `zero-arena-bacend` oracle service. See:
#   ../zero-arena-bacend/README.md  ("Oracle service" section)
# If you operate the oracle yourself, that service's own `.env` holds
# ORACLE_PRIVATE_KEY — never this SDK consumer's `.env`.
