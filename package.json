{
  "name": "zeroarena",
  "version": "0.2.0",
  "description": "Verifiable AI trading agents on 0G — backtest, certify, mint as ERC-7857 iNFT.",
  "license": "MIT",
  "author": "Zero Arena Contributors",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "bin": {
    "zeroarena": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "0g",
    "trading",
    "agent",
    "backtest",
    "verifiable",
    "erc-7857",
    "inft",
    "tee",
    "deterministic",
    "blockchain"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "prepack": "rm -rf dist && npm run build"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.2.9",
    "commander": "^12.0.0",
    "ethers": "^6.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zero-Arena/zero-arena-sdk.git"
  },
  "homepage": "https://github.com/Zero-Arena/zero-arena-sdk#readme",
  "bugs": {
    "url": "https://github.com/Zero-Arena/zero-arena-sdk/issues"
  }
}
